page {
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  font-size: 14px;
  color: #333;
  background: #f5f5f5;
}

.card {
  background: #fff;
  border-radius: 12px;
  padding: 14px;
  margin: 8px 12px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.04);
}

.tag {
  display: inline-block;
  font-size: 10px;
  padding: 2px 8px;
  border-radius: 10px;
  font-weight: 500;
}

.tag-tp { background: #e8f5e9; color: #2d8c4e; }
.tag-tn { background: #fff3e0; color: #e67e22; }
.tag-tng { background: #ffebee; color: #c0392b; }
.tag-ti { background: #f5f5f5; color: #999; }
.tag-th { background: #ffebee; color: #c0392b; }
.tag-tw { background: #fff3e0; color: #e67e22; }
.tag-tc { background: #e3f2fd; color: #1565c0; }

.vu { color: #2d8c4e; }
.vd { color: #c0392b; }
.vn { color: #999; }

.mono { font-family: 'SF Mono', 'Menlo', monospace; }

.flex { display: flex; }
.flex-center { display: flex; align-items: center; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-wrap { display: flex; flex-wrap: wrap; }

.mt8 { margin-top: 8px; }
.mt12 { margin-top: 12px; }
.mb8 { margin-bottom: 8px; }
.fs10 { font-size: 10px; }
.fs11 { font-size: 11px; }
.fs12 { font-size: 12px; }
.fs13 { font-size: 13px; }
.fs15 { font-size: 15px; }
.fs16 { font-size: 16px; }
.fs20 { font-size: 20px; }
.fw600 { font-weight: 600; }
.fw700 { font-weight: 700; }
.text-center { text-align: center; }
.text-muted { color: #777; }

.signal-dot {
  display: inline-block;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  margin-right: 4px;
}
.signal-on { background: #2d8c4e; }
.signal-pending { background: #f39c12; }
.signal-off { background: #ccc; }

.insight-box {
  background: #fafafa;
  border-radius: 8px;
  padding: 10px 12px;
  margin: 8px 0;
  font-size: 12px;
  line-height: 1.6;
}

.loading-center {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40px;
  color: #999;
  font-size: 13px;
}
