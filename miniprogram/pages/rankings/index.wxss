/* Rankings Tab Bar */
.rank-note { text-align: center; padding: 0 12px 4px; color: #999; }
.rk-tabs {
  display: flex;
  gap: 8px;
  padding: 12px;
}
.rk-tab {
  flex: 1;
  text-align: center;
  padding: 10px 0;
  background: #fff;
  border-radius: 12px;
  border: 1px solid #f0f0f0;
}
.rk-tab.active {
  background: #2980b9;
  border-color: #2980b9;
}
.rk-tab.active .rk-tab-title,
.rk-tab.active .rk-tab-desc { color: #fff; }
.rk-tab-title {
  display: block;
  font-size: 13px;
  font-weight: 600;
  color: #333;
}
.rk-tab-desc {
  display: block;
  font-size: 10px;
  color: #999;
  margin-top: 2px;
}

/* Ranking List */
.rk-list {
  padding: 0 12px 12px;
}
.rk-item {
  display: flex;
  align-items: center;
  padding: 10px 12px;
  background: #fff;
  margin-bottom: 1px;
  gap: 10px;
}
.rk-item:first-child { border-radius: 12px 12px 0 0; }
.rk-item:last-child { border-radius: 0 0 12px 12px; margin-bottom: 0; }
.rk-fav {
  background: #fffbf0;
  border-left: 3px solid #f39c12;
}
.rk-rank {
  width: 24px;
  height: 24px;
  line-height: 24px;
  text-align: center;
  font-size: 12px;
  font-weight: 600;
  border-radius: 8px;
  background: #f5f5f5;
  color: #666;
  flex-shrink: 0;
}
.rk-top3 {
  background: #2980b9;
  color: #fff;
}
.rk-info {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.rk-val-box {
  text-align: right;
  flex-shrink: 0;
}
.rk-val-box text { display: block; }
