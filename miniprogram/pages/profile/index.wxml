<view class="page" wx:if="{{loaded}}">
  <!-- 关注城市 -->
  <view class="section-header">
    <text class="section-title">关注城市</text>
    <text class="add-btn" bindtap="addFav">+ 添加</text>
  </view>

  <view wx:if="{{favDetails.length === 0}}" class="card empty-fav">
    <text class="text-muted fs12">还没有关注城市，点击上方「+ 添加」</text>
  </view>

  <view class="card fav-card" wx:for="{{favDetails}}" wx:key="name">
    <view class="fav-header" bindtap="onFavCityTap" data-name="{{item.name}}">
      <view class="fav-info">
        <text class="fw700 fs15">{{item.name}}</text>
        <text class="text-muted fs10"> {{item.tier}}</text>
      </view>
      <view class="tag tag-{{item.tempCls}}">{{item.tempLabel}} {{item.tempScore}}</view>
    </view>
    <view class="fav-row" bindtap="onFavCityTap" data-name="{{item.name}}">
      <view class="fav-metric">
        <text class="fs10 text-muted">均价</text>
        <text class="mono fw600 fs13">{{item.priceStr}}</text>
      </view>
      <view class="fav-metric">
        <text class="fs10 text-muted">年涨跌</text>
        <text class="mono fw600 fs13 {{item.ycCls}}">{{item.ycStr}}</text>
      </view>
      <view class="fav-metric">
        <text class="fs10 text-muted">RS</text>
        <text class="mono fw600 fs13" style="color:{{item.rsColor}}">{{item.rs}}</text>
      </view>
      <view class="fav-metric">
        <text class="fs10 text-muted">判断</text>
        <text class="fw600 fs11 tag tag-{{item.verdictCls}}">{{item.verdict}}</text>
      </view>
    </view>
    <view class="fav-remove" bindtap="removeFav" data-name="{{item.name}}">
      <text class="text-muted fs11">取消关注</text>
    </view>
  </view>

  <!-- 数据信息 -->
  <view class="section-header mt16">
    <text class="section-title">数据信息</text>
  </view>
  <view class="card info-card">
    <view class="info-row">
      <text class="text-muted fs12">更新时间</text>
      <text class="fs12">{{updateTime}}</text>
    </view>
    <view class="info-row">
      <text class="text-muted fs12">城市数量</text>
      <text class="fs12">{{cityCount}}个</text>
    </view>
    <view class="info-row">
      <text class="text-muted fs12">数据来源</text>
      <text class="fs12">安居客+房价行情+房天下</text>
    </view>
    <view class="info-row">
      <text class="text-muted fs12">更新频率</text>
      <text class="fs12">每周日自动更新</text>
    </view>
    <view class="info-row">
      <text class="text-muted fs12">本地缓存</text>
      <text class="fs12">{{cacheSize}}</text>
    </view>
  </view>

  <!-- 方法论 -->
  <view class="section-header mt16">
    <text class="section-title">分析方法论</text>
    <text class="toggle-btn" bindtap="toggleMethod">{{showMethod ? '收起' : '展开'}}</text>
  </view>
  <view class="card method-card" wx:if="{{showMethod}}">
    <view class="method-item">
      <text class="fw600 fs12">温度指标</text>
      <text class="fs11 text-muted">综合价格动量(70%)和成交量趋势(30%)，映射为冰点→过热五档</text>
    </view>
    <view class="method-item">
      <text class="fw600 fs12">RS相对强度</text>
      <text class="fs11 text-muted">城市近12月涨幅在所有城市中的百分位排名(0-100)，50以上跑赢大盘</text>
    </view>
    <view class="method-item">
      <text class="fw600 fs12">信号灯体系</text>
      <text class="fs11 text-muted">止跌→走平→回升三级递进，基于斜率/动量/均线/量价多维度判定</text>
    </view>
    <view class="method-item">
      <text class="fw600 fs12">mktJudge综合判断</text>
      <text class="fs11 text-muted">融合信号灯+量价诊断+趋势强度，输出12种市场状态和置信度</text>
    </view>
    <view class="method-item">
      <text class="fw600 fs12">量价诊断</text>
      <text class="fs11 text-muted">分析近期价格与成交量的联动关系：量价齐升/价升量缩/量升价跌/量价齐跌/缩量盘整</text>
    </view>
    <view class="method-item">
      <text class="fw600 fs12">数据说明</text>
      <text class="fs11 text-muted">成交量为估算模型，租售比/去化周期/溢价率为参考值。所有分析仅供参考，不构成投资建议</text>
    </view>
  </view>

  <!-- 操作 -->
  <view class="card action-card mt16">
    <view class="action-row" bindtap="clearCache">
      <text class="fs13">清除数据缓存</text>
      <text class="text-muted fs12">></text>
    </view>
  </view>

  <view class="footer">
    <text class="text-muted fs10">房产趋势看板 v1.0 · 三源交叉·结论解读·每周更新</text>
  </view>
</view>

<view class="loading-center" wx:else>
  <text>加载中...</text>
</view>
