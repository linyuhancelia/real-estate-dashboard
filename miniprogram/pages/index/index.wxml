<view class="page" wx:if="{{loaded}}">
  <!-- M1 大盘概览 -->
  <view class="card overview-card">
    <view class="ov-header">
      <view class="tag tag-{{natJudge.cls}}">大盘·{{natJudge.verdict}}</view>
      <text class="ov-update text-muted fs10">{{updateTime}}</text>
    </view>
    <view class="ov-body">
      <text>全国：<text class="fw600">{{natJudge.verdict}}</text>（{{natJudge.detail}}）</text>
      <text>\n上海：<text class="fw600">{{shJudge.verdict}}</text>，{{shVsNat}}</text>
    </view>
    <view class="ov-hint text-muted fs10">{{shJudge.hint}}</view>

    <!-- 时间筛选 + 趋势图 -->
    <view class="period-bar">
      <text class="period-btn {{period === '6月' ? 'active' : ''}}" bindtap="switchPeriod" data-p="6月">6月</text>
      <text class="period-btn {{period === '1年' ? 'active' : ''}}" bindtap="switchPeriod" data-p="1年">1年</text>
      <text class="period-btn {{period === '2年' ? 'active' : ''}}" bindtap="switchPeriod" data-p="2年">2年</text>
    </view>
    <view class="chart-box" style="height:200px">
      <f2-canvas canvasId="ovChart" height="200px" bind:bindinit="onOvChartInit"></f2-canvas>
    </view>
  </view>

  <!-- 类别聚合卡片 -->
  <view class="section-title">
    <text class="fw600 fs14">城市类别概览</text>
    <text class="text-muted fs10">Top1异动 = 年变化最大</text>
  </view>

  <view class="tier-list">
    <view class="card tier-card" wx:for="{{tierCards}}" wx:key="tier">
      <view class="tc-header">
        <text class="tc-tier fw600">{{item.tier}}</text>
        <text class="tc-count text-muted fs10">{{item.count}}城</text>
      </view>
      <view class="tc-body">
        <view class="tc-avg">
          <view>
            <text class="text-muted fs10">均价 </text>
            <text class="mono fw600 fs13">{{item.avgPrice}}</text>
          </view>
          <view>
            <text class="text-muted fs10">年变化 </text>
            <text class="mono fw600 {{item.avgYcCls}}">{{item.avgYcStr}}</text>
          </view>
        </view>
        <view class="tc-top1" bindtap="onTop1Tap" data-name="{{item.top1Name}}">
          <view class="tag tag-{{item.top1TempC}}">{{item.top1TempL}}</view>
          <view class="tc-top1-city">
            <text class="fw600 fs12">{{item.top1Name}}</text>
            <text class="mono fw600 fs11 {{item.top1YcCls}}">{{item.top1YcStr}}</text>
            <text class="fs10" style="color:#2980b9"> ></text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- Loading -->
<view class="loading-center" wx:else>
  <text>加载中...</text>
</view>
