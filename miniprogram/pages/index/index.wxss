.overview-card {
  padding: 14px;
}
.ov-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}
.ov-body {
  font-size: 12px;
  line-height: 1.8;
}
.ov-hint {
  margin-top: 6px;
  padding-top: 6px;
  border-top: 1px solid #f0f0f0;
}
.period-bar {
  display: flex;
  gap: 6px;
  margin-top: 10px;
  margin-bottom: 4px;
}
.period-btn {
  font-size: 11px;
  padding: 4px 12px;
  border-radius: 10px;
  background: #f5f5f5;
  color: #999;
}
.period-btn.active {
  background: #2980b9;
  color: #fff;
}
.chart-box {
  position: relative;
}

/* Section title */
.section-title {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 14px 12px 6px;
}

/* Tier grid */
.tier-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  padding: 0 12px 12px;
}
.tier-card {
  width: calc(50% - 4px);
  padding: 12px;
  box-sizing: border-box;
}
.tc-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
  padding-bottom: 6px;
  border-bottom: 1px solid #f0f0f0;
}
.tc-tier {
  font-size: 14px;
}
.tc-avg {
  margin-bottom: 10px;
}
.tc-price {
  margin-bottom: 2px;
}
.tc-yc {
  margin-top: 2px;
}
.tc-top1 {
  background: #fafafa;
  border-radius: 8px;
  padding: 8px;
}
.tc-top1-label {
  display: flex;
  align-items: center;
  margin-bottom: 4px;
}
.tc-top1-city {
  display: flex;
  align-items: center;
}
