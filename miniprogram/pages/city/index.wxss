.city-profile { padding: 14px; }
.cp-top { display: flex; justify-content: space-between; align-items: flex-start; }
.cp-name { font-size: 20px; font-weight: 700; }
.cp-meta { margin-top: 2px; }
.cp-price { margin-top: 10px; display: flex; align-items: center; }
.cp-price-num { font-size: 24px; }
.cp-price-unit { margin-left: 4px; }

.cp-metrics {
  display: flex;
  gap: 12px;
  margin-top: 12px;
  padding: 10px 0;
  border-top: 1px solid #f0f0f0;
  border-bottom: 1px solid #f0f0f0;
}
.cp-metric { flex: 1; text-align: center; }
.cp-ml { display: block; font-size: 10px; margin-bottom: 2px; }
.cp-mv { display: block; font-size: 13px; }

.cp-changes {
  display: flex;
  margin-top: 10px;
  gap: 8px;
}
.cp-chg {
  flex: 1;
  text-align: center;
  padding: 6px 0;
  background: #fafafa;
  border-radius: 8px;
}
.cp-chg-label { display: block; font-size: 10px; margin-bottom: 2px; }
.cp-chg-val { display: block; font-size: 13px; font-weight: 600; }

.cp-signals {
  display: flex;
  align-items: center;
  margin-top: 10px;
  gap: 16px;
}
.cp-sig { display: flex; align-items: center; gap: 4px; }
.cp-rs { margin-left: auto; text-align: right; }
.cp-rs-val { font-size: 22px; display: block; }

.section-title {
  font-size: 13px;
  font-weight: 600;
  color: #333;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}
.period-bar {
  display: flex;
  gap: 4px;
}
.period-btn {
  font-size: 11px;
  padding: 4px 10px;
  border-radius: 10px;
  background: #f5f5f5;
  color: #999;
}
.period-btn.active {
  background: #2980b9;
  color: #fff;
}
.chart-box { position: relative; }

/* Tabs */
.tab-bar {
  display: flex;
  background: #fff;
  padding: 0 12px;
  margin: 8px 12px 0;
  border-radius: 12px 12px 0 0;
  border-bottom: 1px solid #f0f0f0;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 10px 0;
  font-size: 12px;
  color: #999;
  position: relative;
}
.tab-item.active {
  color: #2980b9;
  font-weight: 600;
}
.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 30%;
  right: 30%;
  height: 2px;
  background: #2980b9;
  border-radius: 1px;
}

/* Signal cards */
.signal-card {
  padding: 12px 14px;
}
.sc-name { margin-bottom: 8px; }
.sc-row {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 4px 0;
}
.sc-detail {
  margin-left: auto;
  max-width: 60%;
  text-align: right;
}
.sig-fold {
  text-align: center;
  padding: 10px;
}
.sig-fold-btn {
  display: inline-block;
  font-size: 12px;
  color: #2980b9;
  padding: 6px 16px;
  border: 1px solid #2980b9;
  border-radius: 16px;
  background: #f0f7ff;
}
.sig-inactive {
  opacity: 0.6;
}
.sig-method {
  padding: 10px 14px;
}
.sig-method text {
  display: block;
  line-height: 1.8;
}

/* M4 Property Types */
.pt-card { padding: 12px 14px; }
.pt-header { display: flex; justify-content: space-between; align-items: center; }
.pt-price { margin-top: 6px; }
.pt-changes {
  display: flex;
  gap: 8px;
  margin-top: 8px;
}
.pt-chg {
  flex: 1;
  text-align: center;
  padding: 4px 0;
  background: #fafafa;
  border-radius: 6px;
}
.pt-chg text { display: block; }
.pt-metrics {
  display: flex;
  gap: 12px;
  margin-top: 8px;
  padding-top: 8px;
  border-top: 1px solid #f5f5f5;
}
.pt-signals {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-top: 6px;
}

/* M5 Hot Zones */
.hz-filter-bar {
  white-space: nowrap;
  padding: 8px 14px;
}
.hz-filter-chip {
  display: inline-block;
  font-size: 11px;
  padding: 5px 12px;
  margin-right: 6px;
  border-radius: 12px;
  background: #f5f5f5;
  color: #666;
}
.hz-filter-chip.active {
  background: #e3f2fd;
  color: #1565c0;
  font-weight: 600;
}
.hz-sort-bar {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 6px 14px;
}
.hz-sort-btn {
  font-size: 11px;
  padding: 6px 14px;
  border-radius: 12px;
  background: #f5f5f5;
  color: #666;
}
.hz-sort-btn.active {
  background: #2980b9;
  color: #fff;
}
.hz-card { padding: 10px 14px; }
.hz-header {
  display: flex;
  align-items: center;
  gap: 8px;
}
.hz-rank {
  width: 22px;
  height: 22px;
  line-height: 22px;
  text-align: center;
  font-size: 11px;
  font-weight: 600;
  border-radius: 6px;
  background: #f0f0f0;
  color: #666;
  flex-shrink: 0;
}
.hz-info { flex: 1; min-width: 0; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.hz-right { text-align: right; }
.hz-right text { display: block; }
.hz-bar-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 6px;
}
.hz-bar-bg {
  flex: 1;
  height: 6px;
  background: #f5f5f5;
  border-radius: 3px;
  overflow: hidden;
}
.hz-bar-fill {
  height: 100%;
  border-radius: 3px;
  transition: width 0.3s;
}
.bar-up { background: #2d8c4e; }
.bar-down { background: #c0392b; }
.hz-signals {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-top: 6px;
}
.hz-district { margin-left: auto; }
.hz-rent { margin-left: auto; }

/* M6 Area Rings */
.ar-card { padding: 12px 14px; }
.ar-header { margin-bottom: 6px; }
.ar-price {
  display: flex;
  align-items: baseline;
}
.ar-bar-row { margin-top: 6px; }
.ar-bar-bg {
  height: 8px;
  background: #f5f5f5;
  border-radius: 4px;
  overflow: hidden;
}
.ar-bar-fill {
  height: 100%;
  border-radius: 4px;
  background: linear-gradient(90deg, #3498db, #2980b9);
}
.ar-metrics {
  display: flex;
  gap: 8px;
  margin-top: 8px;
  padding-top: 8px;
  border-top: 1px solid #f5f5f5;
}
.ar-m {
  flex: 1;
  text-align: center;
}
.ar-m text { display: block; }

/* M9 Vol-Price */
.vp-table { padding: 12px 14px; }
.vp-row {
  display: flex;
  padding: 5px 0;
  border-bottom: 1px solid #f8f8f8;
}
.vp-header-row {
  border-bottom: 1px solid #eee;
  padding-bottom: 6px;
  margin-bottom: 2px;
}
.vp-cell {
  flex: 1;
  text-align: center;
}

.data-warn {
  padding: 10px 14px;
  background: #fffbe6;
  border-left: 3px solid #faad14;
}
.data-warn-title {
  display: flex;
  align-items: center;
  margin-bottom: 4px;
}
.data-warn-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: #faad14;
  color: #fff;
  font-size: 12px;
  font-weight: 700;
  margin-right: 6px;
}
.data-warn-desc { margin-bottom: 4px; }
.data-warn-item { color: #8c6e00; padding: 1px 0; }
