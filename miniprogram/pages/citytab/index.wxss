/* City Picker */
.ct-picker {
  background: #fff;
  padding: 8px 12px;
  border-bottom: 1px solid #f0f0f0;
}
.ct-fav-bar {
  display: flex;
  gap: 8px;
  margin-bottom: 8px;
  flex-wrap: wrap;
}
.ct-fav-item {
  font-size: 12px;
  padding: 6px 14px;
  border-radius: 14px;
  background: #f5f5f5;
  color: #666;
}
.ct-fav-item.active {
  background: #2980b9;
  color: #fff;
}
.ct-search-bar {
  display: flex;
  gap: 8px;
  align-items: center;
}
.ct-search {
  flex: 1;
  font-size: 12px;
  padding: 8px 12px;
  border-radius: 14px;
  background: #f5f5f5;
  min-width: 0;
}
.ct-picker-btn {
  font-size: 12px;
  padding: 8px 14px;
  border-radius: 14px;
  background: #e3f2fd;
  color: #1565c0;
  white-space: nowrap;
}
.ct-suggest {
  white-space: nowrap;
  margin-top: 8px;
}
.ct-suggest-item {
  display: inline-block;
  font-size: 12px;
  padding: 6px 12px;
  margin-right: 8px;
  border-radius: 12px;
  background: #fafafa;
  color: #333;
}

/* Reuse city profile styles */
.city-profile { padding: 14px; }
.cp-top { display: flex; justify-content: space-between; align-items: flex-start; }
.cp-name { font-size: 20px; font-weight: 700; }
.cp-meta { margin-top: 2px; }
.cp-price { margin-top: 10px; }
.cp-price-num { font-size: 24px; }
.cp-price-unit { margin-left: 4px; }
.cp-metrics {
  display: flex;
  gap: 12px;
  margin-top: 12px;
  padding: 10px 0;
  border-top: 1px solid #f0f0f0;
  border-bottom: 1px solid #f0f0f0;
}
.cp-metric { flex: 1; text-align: center; }
.cp-ml { display: block; font-size: 10px; margin-bottom: 2px; }
.cp-mv { display: block; font-size: 13px; }
.cp-changes {
  display: flex;
  margin-top: 10px;
  gap: 8px;
}
.cp-chg {
  flex: 1;
  text-align: center;
  padding: 6px 0;
  background: #fafafa;
  border-radius: 8px;
}
.cp-chg-label { display: block; font-size: 10px; margin-bottom: 2px; }
.cp-chg-val { display: block; font-size: 13px; font-weight: 600; }
.cp-signals {
  display: flex;
  align-items: center;
  margin-top: 10px;
  gap: 16px;
}
.cp-sig { display: flex; align-items: center; gap: 4px; }
.cp-rs { margin-left: auto; text-align: right; }
.cp-rs-val { font-size: 22px; display: block; }

/* More link */
.ct-more {
  text-align: center;
  padding: 14px;
}
